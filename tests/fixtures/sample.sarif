{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.15.0",
          "rules": [
            {
              "id": "go/sql-injection",
              "shortDescription": {"text": "SQL Injection"},
              "properties": {
                "tags": ["security", "external/cwe/cwe-89"],
                "security-severity": "9.8"
              }
            },
            {
              "id": "go/xss",
              "shortDescription": {"text": "Cross-site Scripting"},
              "properties": {
                "tags": ["security", "external/cwe/cwe-79"],
                "security-severity": "6.1"
              }
            },
            {
              "id": "go/log-injection",
              "shortDescription": {"text": "Log Injection"},
              "properties": {
                "tags": ["security", "external/cwe/cwe-117"],
                "security-severity": "5.0"
              }
            }
          ]
        }
      },
      "results": [
        {
          "guid": "finding-001",
          "ruleId": "go/sql-injection",
          "level": "error",
          "message": {"text": "This query depends on a user-provided value for the search parameter."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/api/search.go"},
                "region": {"startLine": 42}
              }
            }
          ]
        },
        {
          "guid": "finding-002",
          "ruleId": "go/xss",
          "level": "warning",
          "message": {"text": "Cross-site scripting vulnerability in user profile rendering."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/web/profile.go"},
                "region": {"startLine": 108}
              }
            }
          ]
        },
        {
          "guid": "finding-003",
          "ruleId": "go/log-injection",
          "level": "warning",
          "message": {"text": "User-controlled data written to log without sanitization."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/util/logger.go"},
                "region": {"startLine": 23}
              }
            }
          ]
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "Trivy",
          "version": "0.48.0",
          "rules": [
            {
              "id": "CVE-2021-44228",
              "shortDescription": {"text": "Log4Shell RCE"},
              "properties": {
                "tags": ["vulnerability", "external/cwe/cwe-502"],
                "security-severity": "10.0",
                "cve": "CVE-2021-44228",
                "package": "log4j-core"
              }
            }
          ]
        }
      },
      "results": [
        {
          "guid": "finding-004",
          "ruleId": "CVE-2021-44228",
          "level": "error",
          "message": {"text": "log4j-core 2.14.1 is vulnerable to remote code execution via JNDI injection (Log4Shell)."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "pom.xml"},
                "region": {"startLine": 55}
              }
            }
          ]
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "Gitleaks",
          "version": "8.18.0",
          "rules": [
            {
              "id": "aws-access-key",
              "shortDescription": {"text": "AWS Access Key"}
            }
          ]
        }
      },
      "results": [
        {
          "guid": "finding-005",
          "ruleId": "aws-access-key",
          "level": "error",
          "message": {"text": "AWS access key detected in configuration file."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "config/settings.yaml"},
                "region": {"startLine": 12}
              }
            }
          ]
        }
      ]
    }
  ]
}
